# Required only when running this module directly (deploy-rag-prod.sh injects them automatically):
# vault_mount_path = "<<SECRETS_MANAGER_INSTANCE_ID>>"
# vault_username   = "<<SECRETS_MANAGER_USERNAME>>"
# vault_password   = "<<SECRETS_MANAGER_PASSWORD>>"

rag_secrets = {
  LANGFUSE_INIT_ORG_ID     = "<<LANGFUSE_INIT_ORG_ID>>"
  LANGFUSE_INIT_PROJECT_ID = "<<LANGFUSE_INIT_PROJECT_ID>>"
  LANGFUSE_INIT_USER_EMAIL = "<<LANGFUSE_INIT_USER_EMAIL>>"
  LANGFUSE_INIT_USER_NAME   = "<<LANGFUSE_INIT_USER_NAME>>"
  LANGFUSE_INIT_USER_PASSWORD = "<<LANGFUSE_INIT_USER_PASSWORD>>"
  LANGFUSE_PUBLIC_KEY      = "<<LANGFUSE_PUBLIC_KEY>>"
  LANGFUSE_SECRET_KEY      = "<<LANGFUSE_SECRET_KEY>>"
  LANGFUSE_SALT            = "<<LANGFUSE_SALT>>"
  LANGFUSE_NEXTAUTH        = "<<LANGFUSE_NEXTAUTH>>"
  # Keep RAGAS_OPENAI_API_KEY only if you run RAGAS in OpenAI mode (RAGAS_USE_OPENAI=true).
  # For STACKIT mode, set RAGAS_USE_OPENAI=false in values and this key is not used.
  RAGAS_OPENAI_API_KEY     = "<<RAGAS_OPENAI_API_KEY>>"
  # JSON string for STACKIT DNS webhook auth (service account key JSON).
  # Paste full JSON as heredoc.
  STACKIT_CERT_MANAGER_SA_JSON = <<EOF
<<STACKIT_CERT_MANAGER_SA_JSON>>
EOF
  BASIC_AUTH_USER          = "<<BASIC_AUTH_USER>>"
  BASIC_AUTH_PASSWORD      = "<<BASIC_AUTH_PASSWORD>>"
  BASIC_AUTH               = "<<BASIC_AUTH_HTPASSWD>>"
  CLICKHOUSE_PASSWORD      = "<<CLICKHOUSE_PASSWORD>>"
}

# Optional only when running this module directly.
